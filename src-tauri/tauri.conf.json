{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hiven",
  "version": "0.2.31",
  "identifier": "com.hiven.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Hiven",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "theme": "Dark",
        "transparent": false
      },
      {
        "label": "launcher",
        "title": "Hiven Launcher",
        "url": "index.html?window=launcher",
        "width": 660,
        "height": 390,
        "minWidth": 320,
        "minHeight": 160,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.local/hiven/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://proxy.github.wmgx.top/github/wmgx/hiven/releases/latest/download/latest.json",
        "https://github.com/wmgx/hiven/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZENDZBRjVFMTEzRTdGNjkKUldScGZ6NFJYcTlHL2RCR3c0eXJ4REZSNUVZRktQV1BsdkhoNnBHd3BwMTA5a3lWNE8zeTl5UHcK"
    }
  }
}
